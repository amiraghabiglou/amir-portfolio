---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans antialiased flex flex-col min-h-screen selection:bg-blue-200">

    <header class="border-b border-slate-200 bg-white/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

        <a href="/amir-portfolio/" class="font-bold text-slate-900 tracking-tight hover:text-blue-600 transition-colors text-lg">
          Amir Aghabiglou<span class="text-blue-600 text-xl leading-none">.</span>
        </a>

        <nav class="hidden md:flex gap-8 text-sm font-bold text-slate-600 tracking-wide uppercase">
          <a href="/amir-portfolio/engineering" class="hover:text-blue-600 transition-colors">Engineering</a>
          <a href="/amir-portfolio/solutions" class="hover:text-blue-600 transition-colors">Solutions</a>
          <a href="/amir-portfolio/about" class="hover:text-blue-600 transition-colors">About</a>
          <a href="/amir-portfolio/contact" class="hover:text-blue-600 transition-colors">Contact</a>
        </nav>

      </div>
    </header>

    <div class="flex-grow flex flex-col">
      <slot />
    </div>

    <footer class="border-t border-slate-200 bg-white py-8 mt-auto">
      <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-sm text-slate-500 font-medium">© 2026 Amir Aghabiglou. All rights reserved.</p>

        <div class="flex gap-6 text-sm font-bold text-slate-500 uppercase tracking-wide">
          <a href="https://github.com/amiraghabiglou" target="_blank" class="hover:text-slate-900 transition-colors">GitHub</a>
          <a href="https://scholar.google.com/citations?user=3HkNfsIAAAAJ&hl=en&oi=ao" target="_blank" class="hover:text-slate-900 transition-colors">Google Scholar</a>
          <a href="https://www.linkedin.com/in/amir-aghabaiglou/" target="_blank" class="hover:text-slate-900 transition-colors">LinkedIn</a>
        </div>
      </div>
    </footer>

  </body>
</html>