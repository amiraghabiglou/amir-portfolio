---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
---
<Layout title="Initiate Consultation | Amir Aghabiglou">
  <div class="w-full selection:bg-emerald-200 selection:text-emerald-900 py-12">
    <main class="max-w-4xl mx-auto px-6 pb-24 flex flex-col items-center">

      <header class="mb-12 text-center w-full max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 mb-6">
          Initiate a Consultation
        </h1>
        <p class="text-lg text-slate-600 leading-relaxed">
          Provide the details of your infrastructure challenge below. I review all inquiries analytically to determine if my hybrid AI architectures align with your operational goals.
        </p>
      </header>

      <div class="w-full bg-white p-8 md:p-12 rounded-3xl border border-slate-200 shadow-xl shadow-slate-200/50">
        <form action="https://formspree.io/f/YOUR_ENDPOINT_HERE" method="POST" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="name" class="block text-sm font-bold text-slate-900 uppercase tracking-wide">Full Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 bg-slate-50 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none transition-all" placeholder="Jane Doe">
            </div>
            <div class="space-y-2">
              <label for="email" class="block text-sm font-bold text-slate-900 uppercase tracking-wide">Corporate Email</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-slate-50 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none transition-all" placeholder="jane@company.com">
            </div>
          </div>
          <div class="space-y-2">
            <label for="subject" class="block text-sm font-bold text-slate-900 uppercase tracking-wide">Inquiry Type</label>
            <select id="subject" name="subject" class="w-full px-4 py-3 bg-slate-50 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none transition-all text-slate-700">
              <option value="Smart Grid Anomaly Detection">Smart Grid Anomaly Detection</option>
              <option value="Building Energy Profiling">Building Energy Profiling</option>
              <option value="Custom AI Architecture">Custom AI Architecture</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="space-y-2">
            <label for="message" class="block text-sm font-bold text-slate-900 uppercase tracking-wide">Project Details</label>
            <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 bg-slate-50 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none transition-all resize-none" placeholder="Briefly describe your data scale and operational objective..."></textarea>
          </div>
          <button type="submit" class="w-full md:w-auto px-8 py-4 bg-emerald-600 text-white font-bold rounded-xl hover:bg-emerald-500 transition-colors shadow-lg shadow-emerald-500/30">
            Submit Inquiry &rarr;
          </button>
        </form>
      </div>

    </main>
  </div>
</Layout>